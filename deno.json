{
  "tasks": {
    "dev": "deno run --watch -A serve.ts --lazy",
    "build": "deno run -A build.ts",
    "serve": "deno run -A serve.ts",
    "fresh": "deno run -A fresh.ts && deno task serve"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.12.7"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@tinytools/hono-tools",
    "lib": [
      "deno.window",
      "deno.unstable",
      "dom"
    ]
  }
}
