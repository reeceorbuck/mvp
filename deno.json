{
  "tasks": {
    "dev": "deno run --watch -A serve.ts --lazy",
    "build": "deno run -A build.ts",
    "serve": "deno run -A serve.ts",
    "fresh": "deno run -A fresh.ts && deno task serve"
  },
  "imports": {
    "tinytools": "jsr:@tinytools/hono-tools@^0.1.14",
    "hono": "jsr:@hono/hono@^4.12.12"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "tinytools",
    "lib": [
      "deno.window",
      "deno.unstable",
      "dom"
    ]
  }
}
